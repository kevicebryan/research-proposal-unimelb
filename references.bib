@inproceedings{xu2026integrating,
author = {Xu, Tingjie and Chen, Yisong},
title = {Integrating Generative AI with Human-Centered Pedagogy: An Innovative Path for Vocational Education},
year = {2026},
isbn = {9798400714924},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3771792.3773891},
doi = {10.1145/3771792.3773891},
abstract = {The proliferation of Generative AI necessitates a re-evaluation of educational strategies, particularly in vocational fields. Traditional vocational education faces challenges like limited resource access, high software costs, and a lack of personalized feedback. This paper explores how integrating generative AI, guided by a human-centered philosophy, can address these issues. Through a qualitative analysis of four pedagogical interventions at a vocational school (e-commerce, art, math, and computer science), we find that AI, as a pedagogical co-pilot, boosts instructional efficiency, nurtures creativity, and enables individualized learning. The case studies show AI's ability to lower costs, remove practice barriers, and provide data-driven insights. We synthesize these findings into a conceptual framework for human-centered AI integration, emphasizing AI's role in empowering educators and learners. This research offers a transferable model and discusses ethical considerations for creating effective and equitable learning environments.},
booktitle = {Proceedings of the International Conference on Implementing Generative AI into Telecommunication and Digital Innovation 2025},
pages = {278–283},
numpages = {6},
keywords = {Case Study, Educational Technology, Generative AI, Human-Centered AI, Personalized Learning, Vocational Education},
location = {
},
series = {GAITDI '25}
}

