@inbook{Wang2026SRL,
author = {Wang, Huayi and Wang, Zizhen and Zhou, Tong},
title = {Generative AI and Self-Regulated Learning in Education: A Scientometric Review},
year = {2026},
isbn = {9798400719356},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3778534.3778581},
abstract = {This study presents a scientometric review of the intersection between Generative Artificial Intelligence (Generative AI) and Self-Regulated Learning (SRL) in educational contexts. Based on 79 articles retrieved from Web of Science Core Collection and analyzed using VOSviewer. The keyword co-occurrence analysis revealed five thematic clusters: 1) SRL theory and cognition (metacognition, cognitive load), 2) AI design and learner experience (learning companion, human-AI interaction), 3) higher education practices (feedback, academic writing), 4) instructional design with LLMs (prompt engineering, K-12), and 5) methodological and regional studies (critical thinking, AI in China). This review contributes to the theoretical integration of SRL and AI-enhanced learning, The study identifies three strategic directions: 1) embedding metacognitive scaffolds in AI interfaces rather than providing direct answers, 2) implementing transparency mechanisms to develop critical AI literacy, and 3) evolving assessment practices to evaluate learners’ AI regulation capabilities.},
booktitle = {Proceedings of the 4th International Conference on Artificial Intelligence and Intelligent Information Processing},
pages = {301–307},
numpages = {7}
}

