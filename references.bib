@inproceedings{Jabbour2025,
  author = {Jabbour, Jason and Kleinbard, Kai and Miller, Olivia and Haussman, Robert and Reddi, Vijay Janapa},
  title = {SocratiQ: A Generative AI-Powered Learning Companion for Personalized Education and Broader Accessibility},
  year = {2025},
  isbn = {9798400720079},
  publisher = {Association for Computing Machinery},
  address = {New York, NY, USA},
  url = {https://doi.org/10.1145/3743646.3750010},
  doi = {10.1145/3743646.3750010},
  abstract = {Traditional educational approaches often struggle to provide personalized and interactive learning experiences at scale. In this paper, we present SocratiQ, an AI-powered educational assistant that addresses this challenge by implementing the Socratic method through adaptive learning technologies. The system employs a novel Generative AI-based learning framework that dynamically creates personalized learning pathways based on student responses and comprehension patterns. We provide an account of the core design elements of SocratiQ, practical considerations for its deployment, and user feedback on its effectiveness. Although our implementation focuses on machine learning systems education, the integration approaches we present can inform similar efforts across STEM fields. Through this work, our goal is to advance the understanding of how generative AI technologies can be designed and systematically incorporated into educational resources.},
  booktitle = {Proceedings of the Workshop on Computer Architecture Education},
  articleno = {1},
  numpages = {10},
  location = {Tokyo, Japan},
  series = {WCAE '25}
}

